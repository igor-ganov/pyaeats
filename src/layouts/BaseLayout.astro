---
import '~/styles/global.css';
import { ViewTransitions } from 'astro:transitions';
import { u } from '~/lib/url.ts';

interface Props {
  readonly title: string;
  readonly description?: string;
  /** Render the live-design customizer (only meaningful for the Apetitoso concept). */
  readonly customizer?: boolean;
  /** Extra Google Fonts `family=…` query appended to the stylesheet URL (per concept). */
  readonly fonts?: string;
}

const { title, description, customizer = false, fonts } = Astro.props;
const fontFamilies = ['Inter:wght@400;600;700;800;900', ...(fonts ? [fonts] : [])];
const fontsHref = `https://fonts.googleapis.com/css2?${fontFamilies.map((f) => `family=${f}`).join('&')}&display=swap`;
---

<!doctype html>
<html lang="es" data-theme="light" data-palette="apetitoso" data-shape="redondo">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#ff5a1f" />
    <meta
      name="description"
      content={description ?? 'PyaEats — delivery de comida en Paraguay: tiendas, búsqueda por tipo de comida, promociones, mapa y reseñas.'}
    />
    <title>{title} · PyaEats</title>
    <link rel="icon" type="image/svg+xml" href={u('/favicon.svg')} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href={fontsHref} rel="stylesheet" />
    <ViewTransitions />

    <script is:inline>
      // Pre-paint: resolve theme + design axes + token overrides before first paint.
      (function () {
        var d = document.documentElement;
        try {
          var theme = localStorage.getItem('pya.theme');
          if (theme !== 'light' && theme !== 'dark') {
            theme = matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          }
          d.dataset.theme = theme;

          var axes = ['palette', 'shape'];
          for (var i = 0; i < axes.length; i++) {
            var v = localStorage.getItem('pya.' + axes[i]);
            if (v) d.dataset[axes[i]] = v;
          }

          var glass = localStorage.getItem('pya.glass');
          if (glass) d.dataset.glass = glass;

          var raw = localStorage.getItem('pya.tokens');
          if (raw) {
            var tokens = JSON.parse(raw);
            for (var key in tokens) {
              if (Object.prototype.hasOwnProperty.call(tokens, key)) {
                d.style.setProperty(key, tokens[key]);
              }
            }
          }
        } catch (_) { /* no-op */ }
      })();
    </script>
  </head>
  <body>
    <slot name="topbar" />
    <main>
      <slot />
    </main>
    <slot name="footer" />

    {customizer && <customizer-panel></customizer-panel>}

    <script>
      // Re-apply persisted axes onto the incoming document BEFORE Astro swaps it
      // in — otherwise the new page renders with its default attributes for one
      // frame and the theme/palette/glass flashes during the cross-fade.
      if (!Reflect.get(document, '__pyaSwapHook')) {
        Reflect.set(document, '__pyaSwapHook', true);
        document.addEventListener('astro:before-swap', (event) => {
          const newDoc = Reflect.get(event, 'newDocument');
          if (!(newDoc instanceof Document)) return;
          const d = newDoc.documentElement;
          const apply = (attr: string, key: string): void => {
            const v = globalThis.localStorage?.getItem(key);
            if (v !== null && v !== undefined) d.dataset[attr] = v;
          };
          apply('theme', 'pya.theme');
          apply('palette', 'pya.palette');
          apply('shape', 'pya.shape');
          apply('glass', 'pya.glass');
          try {
            const raw = globalThis.localStorage?.getItem('pya.tokens');
            if (raw === null || raw === undefined) return;
            const parsed: unknown = JSON.parse(raw);
            if (typeof parsed !== 'object' || parsed === null) return;
            for (const [k, val] of Object.entries(parsed)) {
              if (typeof val === 'string') d.style.setProperty(k, val);
            }
          } catch { /* no-op */ }
        });
      }
    </script>

    <script>
      import '~/components/wc/index.ts';
    </script>
  </body>
</html>
